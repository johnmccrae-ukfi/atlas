table gold_massive_futures_minute_candles
	lineageTag: e68bbefb-4c27-4e34-a9ea-f92b3b836134
	sourceLineageTag: [dbo].[gold_massive_futures_minute_candles]

	measure 'Massive Last Price' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR LatestMinuteTimestamp =
			    MAX (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( LatestMinuteTimestamp ),
			        BLANK (),
			        CALCULATE (
			            MAX (
			                gold_massive_futures_minute_candles[Close]
			            ),
			            gold_massive_futures_minute_candles[MinuteTimestamp]
			                = LatestMinuteTimestamp
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Intraday Price
		lineageTag: bb717c4b-518f-4a54-ba81-6aefbd04a13b

	measure 'Massive Session Open' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestMinuteTimestamp =
			    MIN (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( EarliestMinuteTimestamp ),
			        BLANK (),
			        CALCULATE (
			            MAX (
			                gold_massive_futures_minute_candles[Open]
			            ),
			            gold_massive_futures_minute_candles[MinuteTimestamp]
			                = EarliestMinuteTimestamp
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Intraday Price
		lineageTag: c30526e3-8703-46b5-bccc-1878bdb244b2

