		formatString: #,0.00
		displayFolder: Massive\Intraday Price
		lineageTag: 6052185a-da56-4087-9515-fa8d4413c9d7

	measure 'Massive Session Change' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestMinuteTimestamp =
			    MIN (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			VAR LatestMinuteTimestamp =
			    MAX (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			VAR SessionOpen =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_minute_candles[Open]
			        ),
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			            = EarliestMinuteTimestamp
			    )
			VAR SessionClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_minute_candles[Close]
			        ),
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			            = LatestMinuteTimestamp
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( SessionOpen )
			            || ISBLANK ( SessionClose ),
			        BLANK (),
			        SessionClose - SessionOpen
			    )
		formatString: #,0.00;-#,0.00;0.00
		displayFolder: Massive\Intraday Price
		lineageTag: d3396edc-7235-4715-a8f5-7f8dfa87093d

	measure 'Massive Session Change %' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestMinuteTimestamp =
			    MIN (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			VAR LatestMinuteTimestamp =
			    MAX (
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			    )
			VAR SessionOpen =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_minute_candles[Open]
			        ),
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			            = EarliestMinuteTimestamp
			    )
			VAR SessionClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_minute_candles[Close]
			        ),
			        gold_massive_futures_minute_candles[MinuteTimestamp]
			            = LatestMinuteTimestamp
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( SessionOpen )
			            || ISBLANK ( SessionClose ),
			        BLANK (),
			        DIVIDE (
			            SessionClose - SessionOpen,
			            SessionOpen
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Massive\Intraday Price
		lineageTag: db93d98a-61c3-4dcb-8193-6f93199185de

