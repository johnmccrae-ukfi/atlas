		formatString: 0.00000
		displayFolder: Price
		lineageTag: a7d42664-7855-4419-a92f-72c3cd43d66a
		sourceLineageTag: Low
		summarizeBy: none
		sourceColumn: Low

		changedProperty = SummarizeBy

		changedProperty = FormatString

		changedProperty = Description

		changedProperty = DisplayFolder

		annotation SummarizationSetBy = User

	/// Last traded price recorded during the trading day.
	column Close
		dataType: double
		formatString: 0.00000
		displayFolder: Price
		lineageTag: a22a712b-aa30-42b7-9010-c433bbf642a8
		sourceLineageTag: Close
