		formatString: #,0.00
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: f23ab4a8-5123-4a0d-b2b1-a4f279c318a0

	measure 'Massive Trading Day Change' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR SelectedTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR PreviousTradingDate =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        REMOVEFILTERS ( gold_dim_date ),
			        REMOVEFILTERS (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            < SelectedTradingDate
			    )
			VAR SelectedClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Close]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = SelectedTradingDate
			    )
			VAR PreviousClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Close]
			        ),
			        REMOVEFILTERS ( gold_dim_date ),
			        REMOVEFILTERS (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = PreviousTradingDate
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( PreviousTradingDate )
			            || ISBLANK ( SelectedClose )
			            || ISBLANK ( PreviousClose ),
			        BLANK (),
			        SelectedClose - PreviousClose
			    )
		formatString: #,0.00;-#,0.00;0.00
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: b01384de-2f40-49a4-967d-229d87cb0856

	measure 'Massive Trading Day Change %' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR SelectedTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR PreviousTradingDate =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        REMOVEFILTERS ( gold_dim_date ),
			        REMOVEFILTERS (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            < SelectedTradingDate
			    )
			VAR SelectedClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Close]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = SelectedTradingDate
			    )
			VAR PreviousClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Close]
			        ),
			        REMOVEFILTERS ( gold_dim_date ),
			        REMOVEFILTERS (
			            gold_massive_futures_daily_candles[TradingDate]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = PreviousTradingDate
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( PreviousTradingDate )
			            || ISBLANK ( SelectedClose )
			            || ISBLANK ( PreviousClose ),
			        BLANK (),
			        DIVIDE (
			            SelectedClose - PreviousClose,
			            PreviousClose
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: c9aee85a-a3cb-45d8-89c8-56ae794cd9fc

	measure 'Massive 5-Day MA Close' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR CurrentTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR LastFiveTradingDates =
			    TOPN (
			        5,
			        CALCULATETABLE (
			            VALUES (
			                gold_massive_futures_daily_candles[TradingDate]
			            ),
			            REMOVEFILTERS ( gold_dim_date ),
			            REMOVEFILTERS (
			                gold_massive_futures_daily_candles[TradingDate]
			            ),
			            gold_massive_futures_daily_candles[TradingDate]
			                <= CurrentTradingDate
			        ),
			        gold_massive_futures_daily_candles[TradingDate],
			        DESC
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( CurrentTradingDate ),
			        BLANK (),
			        AVERAGEX (
			            LastFiveTradingDates,
			            VAR TradingDateValue =
			                gold_massive_futures_daily_candles[TradingDate]
			            RETURN
			                CALCULATE (
			                    MAX (
			                        gold_massive_futures_daily_candles[Close]
			                    ),
			                    REMOVEFILTERS ( gold_dim_date ),
			                    REMOVEFILTERS (
			                        gold_massive_futures_daily_candles[TradingDate]
			                    ),
			                    gold_massive_futures_daily_candles[TradingDate]
			                        = TradingDateValue
			                )
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: 977c7565-5245-476d-b711-43104328f340

