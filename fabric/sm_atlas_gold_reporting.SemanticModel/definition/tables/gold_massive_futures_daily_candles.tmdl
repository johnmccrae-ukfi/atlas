table gold_massive_futures_daily_candles
	lineageTag: 40b9e56b-0cce-4a9d-b5b3-e572c8f748cf
	sourceLineageTag: [dbo].[gold_massive_futures_daily_candles]

	measure 'Massive Selected Period Close' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR LatestSelectedTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        CALCULATE (
			            MAX (
			                gold_massive_futures_daily_candles[Close]
			            ),
			            gold_massive_futures_daily_candles[TradingDate]
			                = LatestSelectedTradingDate
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Price
		lineageTag: e9160671-7f79-46bd-842d-e98aa67e74fd

	measure 'Massive Selected Period Open' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestSelectedTradingDate =
			    MIN (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        CALCULATE (
			            MAX (
			                gold_massive_futures_daily_candles[Open]
			            ),
			            gold_massive_futures_daily_candles[TradingDate]
			                = EarliestSelectedTradingDate
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Price
		lineageTag: 05167252-a605-4eeb-b44c-3b1397ce4164

	measure 'Massive Selected Period High' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        MAX (
			            gold_massive_futures_daily_candles[High]
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Price
		lineageTag: dae8193c-8dda-4b2c-b072-f52c22a95b3a

	measure 'Massive Selected Period Low' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        MIN (
			            gold_massive_futures_daily_candles[Low]
			        )
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Price
		lineageTag: 64514ed5-04ad-4d9b-900c-eeb61741f7a7

	measure 'Massive Selected Period Return %' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestSelectedTradingDate =
			    MIN (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR LatestSelectedTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR PeriodOpen =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Open]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = EarliestSelectedTradingDate
			    )
			VAR PeriodClose =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Close]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = LatestSelectedTradingDate
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( PeriodOpen )
			            || ISBLANK ( PeriodClose ),
			        BLANK (),
			        DIVIDE (
			            PeriodClose - PeriodOpen,
			            PeriodOpen
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Massive\Daily Price
		lineageTag: 0f3af906-8c1c-429d-8281-fd1d5a5d2cec

	measure 'Massive Selected Period Range' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR PeriodHigh =
			    MAX (
			        gold_massive_futures_daily_candles[High]
			    )
			VAR PeriodLow =
			    MIN (
			        gold_massive_futures_daily_candles[Low]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        PeriodHigh - PeriodLow
			    )
		formatString: #,0.00
		displayFolder: Massive\Daily Price
		lineageTag: 2dadd3e2-f8a3-4655-b65e-34e4af2b3ac9

	measure 'Massive Selected Period Range %' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR EarliestSelectedTradingDate =
			    MIN (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			VAR PeriodOpen =
			    CALCULATE (
			        MAX (
			            gold_massive_futures_daily_candles[Open]
			        ),
			        gold_massive_futures_daily_candles[TradingDate]
			            = EarliestSelectedTradingDate
			    )
			VAR PeriodHigh =
			    MAX (
			        gold_massive_futures_daily_candles[High]
			    )
			VAR PeriodLow =
			    MIN (
			        gold_massive_futures_daily_candles[Low]
			    )
			VAR PeriodRange =
			    PeriodHigh - PeriodLow
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( PeriodOpen ),
			        BLANK (),
			        DIVIDE (
			            PeriodRange,
			            PeriodOpen
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Massive\Daily Price
		lineageTag: 56e77313-bcca-4687-88b4-90ed2fe11878

	measure 'Massive Trading Days' =
			
			DISTINCTCOUNT (
			    gold_massive_futures_daily_candles[TradingDate]
			)
		formatString: #,0
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: 37bff484-ef9c-4609-af59-bedc8db4a825

	measure 'Massive Selected Trading Date' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			RETURN
			    IF (
			        NOT HasOneContract,
			        BLANK (),
			        MAX (
			            gold_massive_futures_daily_candles[TradingDate]
			        )
			    )
		formatString: dd/MM/yyyy
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: 6b2f5e30-bcb0-4d00-86f0-abb4f77792c0

	measure 'Massive Previous Trading Date' =
			
			VAR HasOneContract =
			    HASONEVALUE (
			        gold_dim_instrument[AtlasContractKey]
			    )
			VAR SelectedTradingDate =
			    MAX (
			        gold_massive_futures_daily_candles[TradingDate]
			    )
			RETURN
			    IF (
			        NOT HasOneContract
			            || ISBLANK ( SelectedTradingDate ),
			        BLANK (),
			        CALCULATE (
			            MAX (
			                gold_massive_futures_daily_candles[TradingDate]
			            ),
			            REMOVEFILTERS ( gold_dim_date ),
			            REMOVEFILTERS (
			                gold_massive_futures_daily_candles[TradingDate]
			            ),
			            gold_massive_futures_daily_candles[TradingDate]
			                < SelectedTradingDate
			        )
			    )
		formatString: dd/MM/yyyy
		displayFolder: Massive\Daily Time Intelligence
		lineageTag: 492efb8f-32e6-484e-b4dd-6d616502217b

